# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
.vscode/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# ccstatus binary
/ccstatus
cmd/ccstatus/ccstatus
dist/

# GitHub Actions
!/.github/workflows/*.yml

# CICD Config
!.gitignore
!.typos.toml
!.golangci.yml
!.github/*.yml
!.codecov.yml
!.goreleaser.yml

# Whitelist
!*.go
!*.md
!rfcs/*.md
!**/testdata/**/*.json
!**/testdata/**/*.jsonl

# Go module files
!go.mod
!go.sum
!docs/*.png
